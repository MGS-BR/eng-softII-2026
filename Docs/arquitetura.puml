@startuml
left to right direction
skinparam packageStyle rectangle

actor Contador
actor Cliente

rectangle "Sistema Contabilidade Ágil" {

  package "Frontend (Web/Mobile)" {
    (Interface do Usuário) as UI
  }

  package "Backend (API)" {
    (Autenticação) as Auth
    (Gestão de Clientes) as Clientes
    (Upload de Documentos) as Upload
    (Processamento de Documentos) as Proc
    (Gestão de Lançamentos) as Lancamentos
    (Notificações) as Notif
  }

  package "Serviços Externos" {
    (Serviço de IA) as IA
  }

  package "Persistência" {
    (Banco de Dados) as DB
    (Armazenamento de Arquivos) as Storage
  }
}

Contador --> UI
Cliente --> UI

UI --> Auth
UI --> Clientes
UI --> Upload
UI --> Lancamentos

Upload --> Storage
Upload --> Proc

Proc --> IA
Proc --> DB

Clientes --> DB
Lancamentos --> DB

Notif --> Contador

@enduml
